####### Install

install_examplefiles: first FORCE
	@test -d $(INSTALL_ROOT:@msyshack@%=%)/share/savvycan/examples || mkdir -p $(INSTALL_ROOT:@msyshack@%=%)/share/savvycan/examples
	$(QINSTALL) E:/SavvyCAN/examples $(INSTALL_ROOT:@msyshack@%=%)/share/savvycan/examples/examples

uninstall_examplefiles: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT:@msyshack@%=%)/share/savvycan/examples/examples
	-$(DEL_DIR) $(INSTALL_ROOT:@msyshack@%=%)/share/savvycan/examples/ 


install_iconfiles: first FORCE
	@test -d $(INSTALL_ROOT:@msyshack@%=%)/share || mkdir -p $(INSTALL_ROOT:@msyshack@%=%)/share
	$(QINSTALL) E:/SavvyCAN/icons $(INSTALL_ROOT:@msyshack@%=%)/share/icons

uninstall_iconfiles: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT:@msyshack@%=%)/share/icons
	-$(DEL_DIR) $(INSTALL_ROOT:@msyshack@%=%)/share/ 


install_helpfiles: first FORCE
	@test -d $(INSTALL_ROOT:@msyshack@%=%)/bin/help || mkdir -p $(INSTALL_ROOT:@msyshack@%=%)/bin/help
	$(QINSTALL) E:/SavvyCAN/help/bisector.md $(INSTALL_ROOT:@msyshack@%=%)/bin/help/bisector.md
	$(QINSTALL) E:/SavvyCAN/help/canbridge.md $(INSTALL_ROOT:@msyshack@%=%)/bin/help/canbridge.md
	$(QINSTALL) E:/SavvyCAN/help/connectionwindow.md $(INSTALL_ROOT:@msyshack@%=%)/bin/help/connectionwindow.md
	$(QINSTALL) E:/SavvyCAN/help/customsender.md $(INSTALL_ROOT:@msyshack@%=%)/bin/help/customsender.md
